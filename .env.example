# Copy to `.env.local` for local dev. Never commit real secrets.

# Main GDC API (gdc-backend) — no trailing slash
#
# Local dev: leave UNSET so the browser calls the Next.js app origin (/api/...)
# and next.config.ts rewrites proxy to gdc-backend (avoids CORS / blocked responses).
# Override BACKEND_PROXY_URL if your API is not on 127.0.0.1:5000.
#
# NEXT_PUBLIC_API_URL=http://localhost:5000
#
# Socket.IO: default = same tab origin; `next.config.ts` rewrites `/socket.io/*` → BACKEND_PROXY_URL.
# Only set this if CRM and API cannot share one origin (no rewrite), e.g. direct gdc-backend URL:
# NEXT_PUBLIC_SOCKET_URL=https://your-api.onrender.com
BACKEND_PROXY_URL=http://127.0.0.1:5000

# ---------------------------------------------------------------------------
# Task microservice (taskmanagment-backend) — same JWT as gdc-backend
# ---------------------------------------------------------------------------
# Local: port 5001
NEXT_PUBLIC_TASK_API_URL=http://localhost:5001
#
# Hosted on Render (replace with your URL if different) — HTTPS, NO trailing slash:
# NEXT_PUBLIC_TASK_API_URL=https://taskmanagment-backend-34i7.onrender.com

# ---------------------------------------------------------------------------
# Chat microservice (chat-backend)
# ---------------------------------------------------------------------------
# Local: port 5002
# NEXT_PUBLIC_CHAT_API_URL=http://localhost:5002
#
# Hosted on Render — HTTPS, NO trailing slash:
# NEXT_PUBLIC_CHAT_API_URL=https://chat-backend-y6j2.onrender.com

# ---------------------------------------------------------------------------
# Attendance microservice (Attendence-Service)
# ---------------------------------------------------------------------------
# Local: port 5003
# NEXT_PUBLIC_ATTENDANCE_API_URL=http://localhost:5003
#
# Hosted on Render — HTTPS, NO trailing slash:
# NEXT_PUBLIC_ATTENDANCE_API_URL=https://attendence-service-rdvv.onrender.com
#
# Geo-fencing / staging:
# - On Attendence-Service (Render): bypass requires BOTH non-production ATTENDANCE_ENV (e.g. staging)
#   AND ATTENDANCE_GEOFENCE_BYPASS=1 — see Attendence-Service/.env.example.
# - CORS_ORIGIN on Render must include this CRM origin (e.g. https://gdc-crm-woad.vercel.app).
# - Optional: set NEXT_PUBLIC_ATTENDANCE_API_DEBUG=1 on Vercel to log the resolved attendance base URL in the browser console.

# ---------------------------------------------------------------------------
# Vercel (Dashboard) — Settings → Environment Variables → Production
# ---------------------------------------------------------------------------
# 1) NEXT_PUBLIC_API_URL = your gdc-backend URL (e.g. https://xxx.onrender.com)
# 2) NEXT_PUBLIC_TASK_API_URL = https://taskmanagment-backend-34i7.onrender.com
# 3) NEXT_PUBLIC_ATTENDANCE_API_URL = https://attendence-service-rdvv.onrender.com
# 4) Redeploy after saving (Next.js bakes NEXT_PUBLIC_* at build time).
#
# On taskmanagment-backend (Render): set FRONTEND_ORIGINS to include your Vercel URL, e.g.
#   https://gdc-crm-woad.vercel.app
# (comma-separated, no spaces unless quoted)

# Optional: overrides X-Client-Version on API requests
# NEXT_PUBLIC_APP_VERSION=0.1.0
