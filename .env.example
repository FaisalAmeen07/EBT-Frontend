# Copy to `.env.local` for local dev. Never commit real secrets.

# Main auth API (authservices-backend) — no trailing slash
#
# Local dev: leave NEXT_PUBLIC_API_URL UNSET so the browser calls the Next.js app origin (/api/...)
# and next.config.ts rewrites proxy to BACKEND_PROXY_URL (avoids CORS).
#
# NEXT_PUBLIC_API_URL=http://localhost:5000
#
# Production (Render):
# NEXT_PUBLIC_API_URL=https://authservices-backend.onrender.com
#
# Socket.IO: default = same tab origin; rewrites `/socket.io/*` → BACKEND_PROXY_URL locally.
# Production direct socket:
# NEXT_PUBLIC_SOCKET_URL=https://authservices-backend.onrender.com
BACKEND_PROXY_URL=http://127.0.0.1:5000

# ---------------------------------------------------------------------------
# Task microservice (taskservice-backend)
# ---------------------------------------------------------------------------
# Local:
# NEXT_PUBLIC_TASK_API_URL=http://localhost:4000
#
# Production (Render):
# NEXT_PUBLIC_TASK_API_URL=https://taskservice-backend.onrender.com

# ---------------------------------------------------------------------------
# Chat microservice (chatservice-backend)
# ---------------------------------------------------------------------------
# Local:
# NEXT_PUBLIC_CHAT_API_URL=http://localhost:5003
#
# Production (Render):
# NEXT_PUBLIC_CHAT_API_URL=https://chatservice-backend.onrender.com

# ---------------------------------------------------------------------------
# Attendance microservice (attendenceservice-backend)
# ---------------------------------------------------------------------------
# Local:
# NEXT_PUBLIC_ATTENDANCE_API_URL=http://localhost:5000
#
# Production (Render):
# NEXT_PUBLIC_ATTENDANCE_API_URL=https://attendenceservice-backend.onrender.com
#
# Force remote attendance API during local dev:
# NEXT_PUBLIC_ATTENDANCE_API_FORCE_REMOTE=1

# ---------------------------------------------------------------------------
# Vercel (Dashboard) — Settings → Environment Variables → Production
# ---------------------------------------------------------------------------
# 1) NEXT_PUBLIC_API_URL = https://authservices-backend.onrender.com
# 2) NEXT_PUBLIC_TASK_API_URL = https://taskservice-backend.onrender.com
# 3) NEXT_PUBLIC_CHAT_API_URL = https://chatservice-backend.onrender.com
# 4) NEXT_PUBLIC_ATTENDANCE_API_URL = https://attendenceservice-backend.onrender.com
# 5) NEXT_PUBLIC_SOCKET_URL = https://authservices-backend.onrender.com (optional)
# 6) Redeploy after saving (Next.js bakes NEXT_PUBLIC_* at build time).
#
# Netlify (https://evelatebrighttec.netlify.app):
# - If env vars are unset at build, chat uses same-origin /api/chats proxy (next.config rewrites).
# - Socket defaults to https://authservices-backend.onrender.com when NEXT_PUBLIC_SOCKET_URL is unset.
# - Optional: set all NEXT_PUBLIC_* vars above in Netlify → Site settings → Environment variables.

# Optional: overrides X-Client-Version on API requests
# NEXT_PUBLIC_APP_VERSION=0.1.0
